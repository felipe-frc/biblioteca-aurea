@model Biblioteca.Web.ViewModels.CatalogoIndexViewModel

@{
    ViewData["Title"] = "Catálogo Público";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";
}

<section class="crud-page crud-page-livros">
    <div class="container">
        @if (TempData["Erro"] is not null)
        {
            <div class="crud-alert crud-alert-danger">@TempData["Erro"]</div>
        }

        <div class="crud-header">
            <div>
                <h1 class="crud-title">Catálogo Público</h1>
                <span class="crud-line"></span>
                <p class="mt-3 text-muted">
                    Consulte os livros cadastrados na Biblioteca Áurea e verifique a disponibilidade de cada obra.
                </p>
            </div>

            <a class="crud-secondary-btn" asp-controller="Admin" asp-action="Login">
                Login Administrativo
            </a>
        </div>

        <div class="crud-form-card mb-4">
            <form asp-action="Index" method="get">
                <input type="hidden" name="page" value="1" />

                <div class="crud-form-grid">
                    <div class="crud-form-group">
                        <label for="busca" class="crud-form-label">Buscar livro</label>
                        <input id="busca"
                               name="busca"
                               value="@Model.Busca"
                               class="crud-form-control"
                               placeholder="Digite título, autor ou editora" />
                    </div>

                    <div class="crud-form-group crud-form-group-small">
                        <label for="disponibilidade" class="crud-form-label">Disponibilidade</label>
                        <select id="disponibilidade"
                                name="disponibilidade"
                                class="crud-form-control crud-form-select">
                            @if (Model.Disponibilidade == "todos")
                            {
                                <option value="todos" selected>Todos</option>
                            }
                            else
                            {
                                <option value="todos">Todos</option>
                            }

                            @if (Model.Disponibilidade == "disponiveis")
                            {
                                <option value="disponiveis" selected>Disponíveis</option>
                            }
                            else
                            {
                                <option value="disponiveis">Disponíveis</option>
                            }

                            @if (Model.Disponibilidade == "emprestados")
                            {
                                <option value="emprestados" selected>Emprestados</option>
                            }
                            else
                            {
                                <option value="emprestados">Emprestados</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="crud-form-actions">
                    <button type="submit" class="crud-primary-btn">Filtrar</button>
                    <a asp-action="Index" class="crud-secondary-btn">Limpar Filtros</a>
                </div>
            </form>
        </div>

        @if (!Model.HasLivros)
        {
            <div class="crud-empty-state">
                <h3>Nenhum livro encontrado.</h3>

                @if (Model.HasFiltros)
                {
                    <p>Nenhum resultado corresponde aos filtros informados.</p>
                    <a asp-action="Index" class="crud-secondary-btn mt-3">Limpar Filtros</a>
                }
                else
                {
                    <p>O acervo ainda não possui livros cadastrados.</p>
                }
            </div>
        }
        else
        {
            <div class="row g-4 crud-stats-row mb-4">
                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Livros Encontrados</span>
                        <strong class="crud-stat-value">@Model.TotalLivros</strong>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Disponíveis</span>
                        <strong class="crud-stat-value">@Model.TotalDisponiveis</strong>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Emprestados</span>
                        <strong class="crud-stat-value">@Model.TotalEmprestados</strong>
                    </div>
                </div>
            </div>

            <div class="crud-table-card">
                <div class="crud-table-wrap">
                    <table class="crud-table">
                        <thead>
                            <tr>
                                <th>Título</th>
                                <th>Autor</th>
                                <th>Editora</th>
                                <th>Edição</th>
                                <th>Publicação</th>
                                <th>Páginas</th>
                                <th>Disponibilidade</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var livro in Model.Livros)
                            {
                                <tr>
                                    <td class="crud-strong" data-label="Título">@livro.Titulo</td>
                                    <td data-label="Autor">@livro.Autor</td>
                                    <td data-label="Editora">@livro.Editora</td>
                                    <td data-label="Edição">@livro.Edicao</td>
                                    <td data-label="Publicação">@livro.DataPublicacao.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Páginas">@livro.NumeroPaginas</td>
                                    <td data-label="Disponibilidade">
                                        <span class="crud-pill @(livro.Disponivel ? "crud-pill-success" : "crud-pill-danger")">
                                            @(livro.Disponivel ? "Disponível" : "Emprestado")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Paginação do catálogo" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-controller="Catalogo"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-busca="@Model.Busca"
                               asp-route-disponibilidade="@Model.Disponibilidade">
                                Anterior
                            </a>
                        </li>

                        @for (var i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-controller="Catalogo"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-busca="@Model.Busca"
                                   asp-route-disponibilidade="@Model.Disponibilidade">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-controller="Catalogo"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-busca="@Model.Busca"
                               asp-route-disponibilidade="@Model.Disponibilidade">
                                Próxima
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>