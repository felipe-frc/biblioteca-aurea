@model Biblioteca.Web.ViewModels.UsuariosIndexViewModel

@{
    ViewData["Title"] = "Usuários";
}

<section class="crud-page crud-page-usuarios">
    <div class="container">
        @if (TempData["Erro"] is not null)
        {
            <div class="crud-alert crud-alert-danger">@TempData["Erro"]</div>
        }

        @if (TempData["Sucesso"] is not null)
        {
            <div class="crud-alert crud-alert-success">@TempData["Sucesso"]</div>
        }

        <div class="crud-header">
            <h1 class="crud-title">Usuários</h1>
            <span class="crud-line"></span>
            <a class="crud-primary-btn" asp-controller="Usuarios" asp-action="Create">+ Novo Usuário</a>
        </div>

        @if (!Model.HasUsuarios)
        {
            <div class="crud-empty-state">
                <h3>Nenhum usuário cadastrado.</h3>
                <p>Cadastre o primeiro usuário para começar a gerenciar a biblioteca.</p>
            </div>
        }
        else
        {
            <div class="crud-table-card">
                <div class="crud-table-wrap">
                    <table class="crud-table">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Nome</th>
                                <th>Email</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var usuario in Model.Usuarios)
                            {
                                <tr>
                                    <td class="crud-id" data-label="Id">@usuario.Id</td>
                                    <td class="crud-strong" data-label="Nome">@usuario.Nome</td>
                                    <td data-label="Email">@usuario.Email</td>
                                    <td class="crud-actions-cell" data-label="Ações">
                                        <div class="crud-actions">
                                            <a class="crud-action-btn crud-action-btn-edit"
                                               asp-controller="Usuarios"
                                               asp-action="Edit"
                                               asp-route-id="@usuario.Id">
                                                <span class="crud-action-icon" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M12 20h9" />
                                                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                                                    </svg>
                                                </span>
                                                Editar
                                            </a>

                                            <a class="crud-action-btn crud-action-btn-delete"
                                               asp-controller="Usuarios"
                                               asp-action="Delete"
                                               asp-route-id="@usuario.Id">
                                                <span class="crud-action-icon" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M3 6h18" />
                                                        <path d="M8 6V4h8v2" />
                                                        <path d="M19 6l-1 14H6L5 6" />
                                                        <path d="M10 11v6" />
                                                        <path d="M14 11v6" />
                                                    </svg>
                                                </span>
                                                Excluir
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.TotalPages > 0)
            {
                <nav class="crud-pagination" aria-label="Paginação">
                    @if (Model.HasPreviousPage)
                    {
                        <a class="crud-pagination-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)">
                            Anterior
                        </a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Anterior</span>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span class="crud-pagination-link is-active">@i</span>
                        }
                        else
                        {
                            <a class="crud-pagination-link"
                               asp-action="Index"
                               asp-route-page="@i">
                                @i
                            </a>
                        }
                    }

                    @if (Model.HasNextPage)
                    {
                        <a class="crud-pagination-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)">
                            Próxima
                        </a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Próxima</span>
                    }
                </nav>
            }

            <div class="row g-4 crud-stats-row">
                <div class="col-lg-6 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Total de Usuários</span>
                        <strong class="crud-stat-value">@Model.TotalUsuarios</strong>
                    </div>
                </div>

                <div class="col-lg-6 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Usuários Inadimplentes</span>
                        <strong class="crud-stat-value">@Model.UsuariosInadimplentes</strong>
                    </div>
                </div>
            </div>
        }
    </div>
</section>