@model Biblioteca.Web.ViewModels.EmprestimosIndexViewModel

@{
    ViewData["Title"] = "Empréstimos";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";
}

<section class="crud-page crud-page-emprestimos">
    <div class="container">
        @if (TempData["Erro"] is not null)
        {
            <div class="crud-alert crud-alert-danger">@TempData["Erro"]</div>
        }

        @if (TempData["Sucesso"] is not null)
        {
            <div class="crud-alert crud-alert-success">@TempData["Sucesso"]</div>
        }

        <div class="crud-header">
            <h1 class="crud-title">Empréstimos</h1>
            <span class="crud-line"></span>
            <a asp-controller="Emprestimos" asp-action="Create" class="crud-primary-btn">+ Novo Empréstimo</a>
        </div>

        <div class="crud-form-card mb-4">
            <form asp-controller="Emprestimos" asp-action="Index" method="get">
                <div class="crud-form-grid">
                    <div class="crud-form-group crud-form-group-small">
                        <label for="filtroStatus" class="crud-form-label">Status do Empréstimo</label>

                        <select id="filtroStatus"
                                name="filtroStatus"
                                class="crud-form-control crud-form-select">
                            @if (Model.FiltroStatus == "todos")
                            {
                                <option value="todos" selected>Todos</option>
                            }
                            else
                            {
                                <option value="todos">Todos</option>
                            }

                            @if (Model.FiltroStatus == "ativos")
                            {
                                <option value="ativos" selected>Ativos</option>
                            }
                            else
                            {
                                <option value="ativos">Ativos</option>
                            }

                            @if (Model.FiltroStatus == "atrasados")
                            {
                                <option value="atrasados" selected>Atrasados</option>
                            }
                            else
                            {
                                <option value="atrasados">Atrasados</option>
                            }

                            @if (Model.FiltroStatus == "devolvidos")
                            {
                                <option value="devolvidos" selected>Devolvidos</option>
                            }
                            else
                            {
                                <option value="devolvidos">Devolvidos</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="crud-form-actions">
                    <button type="submit" class="crud-primary-btn">Filtrar</button>
                    <a asp-controller="Emprestimos" asp-action="Index" class="crud-secondary-btn">Limpar Filtros</a>
                </div>
            </form>
        </div>

        @if (!Model.HasEmprestimos)
        {
            <div class="crud-empty-state">
                <h3>Nenhum empréstimo encontrado.</h3>

                @if (Model.HasFiltroStatus)
                {
                    <p>Nenhum resultado corresponde ao status selecionado.</p>
                    <a asp-controller="Emprestimos" asp-action="Index" class="crud-secondary-btn mt-3">Limpar Filtros</a>
                }
                else
                {
                    <p>Registre o primeiro empréstimo para acompanhar as devoluções.</p>
                }
            </div>
        }
        else
        {
            <div class="crud-table-card">
                <div class="crud-table-wrap">
                    <table class="crud-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Livro</th>
                                <th>Usuário</th>
                                <th>Retirada</th>
                                <th>Previsão</th>
                                <th>Devolução</th>
                                <th>Status</th>
                                <th>Atraso</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emprestimo in Model.Emprestimos)
                            {
                                var estaAtrasado = emprestimo.DataDevolucao is null && emprestimo.EstaAtrasado(Model.Hoje);
                                var diasAtraso = estaAtrasado
                                ? (Model.Hoje - emprestimo.DataPrevistaDevolucao.Date).Days
                                : 0;

                                var statusTexto = emprestimo.DataDevolucao is not null
                                ? "Devolvido"
                                : estaAtrasado
                                ? "Atrasado"
                                : "Ativo";

                                var statusClasse = emprestimo.DataDevolucao is not null
                                ? "crud-pill-success"
                                : estaAtrasado
                                ? "crud-pill-danger"
                                : "crud-pill-warning";

                                <tr>
                                    <td class="crud-id" data-label="ID">@emprestimo.Id</td>
                                    <td class="crud-strong" data-label="Livro">@emprestimo.Livro?.Titulo</td>
                                    <td data-label="Usuário">@emprestimo.Usuario?.Nome</td>
                                    <td data-label="Retirada">@emprestimo.DataEmprestimo.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Previsão">@emprestimo.DataPrevistaDevolucao.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Devolução">
                                        @(emprestimo.DataDevolucao is null ? "-" : emprestimo.DataDevolucao.Value.ToString("dd/MM/yyyy"))
                                    </td>
                                    <td data-label="Status">
                                        <span class="crud-pill @statusClasse">
                                            @statusTexto
                                        </span>
                                    </td>
                                    <td data-label="Atraso">
                                        @if (estaAtrasado)
                                        {
                                            <span class="text-danger fw-semibold">
                                                @diasAtraso @(diasAtraso == 1 ? "dia" : "dias")
                                            </span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td class="crud-actions-cell" data-label="Ações">
                                        <div class="crud-actions">
                                            @if (emprestimo.DataDevolucao is null)
                                            {
                                                <form asp-controller="Emprestimos"
                                                      asp-action="Devolver"
                                                      asp-route-id="@emprestimo.Id"
                                                      method="post"
                                                      class="crud-inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="crud-action-btn crud-action-btn-edit">
                                                        <span class="crud-action-icon" aria-hidden="true">
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                <path d="M21 12a9 9 0 1 1-3.2-6.9" />
                                                                <path d="M21 3v6h-6" />
                                                            </svg>
                                                        </span>
                                                        Devolver
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="crud-action-dash">—</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.TotalPages > 0)
            {
                <nav class="crud-pagination" aria-label="Paginação">
                    @if (Model.HasPreviousPage)
                    {
                        <a class="crud-pagination-link"
                           asp-controller="Emprestimos"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-filtroStatus="@Model.FiltroStatus">
                            Anterior
                        </a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Anterior</span>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span class="crud-pagination-link is-active">@i</span>
                        }
                        else
                        {
                            <a class="crud-pagination-link"
                               asp-controller="Emprestimos"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-filtroStatus="@Model.FiltroStatus">
                                @i
                            </a>
                        }
                    }

                    @if (Model.HasNextPage)
                    {
                        <a class="crud-pagination-link"
                           asp-controller="Emprestimos"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-filtroStatus="@Model.FiltroStatus">
                            Próxima
                        </a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Próxima</span>
                    }
                </nav>
            }

            <div class="row g-4 crud-stats-row">
                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Empréstimos Encontrados</span>
                        <strong class="crud-stat-value">@Model.TotalEmprestimos</strong>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Ativos</span>
                        <strong class="crud-stat-value">@Model.Ativos</strong>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Atrasados</span>
                        <strong class="crud-stat-value">@Model.Atrasados</strong>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Devolvidos</span>
                        <strong class="crud-stat-value">@Model.Devolvidos</strong>
                    </div>
                </div>
            </div>
        }
    </div>
</section>