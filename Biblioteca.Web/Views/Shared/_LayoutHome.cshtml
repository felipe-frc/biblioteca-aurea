<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <meta name="description" content="Biblioteca Áurea - Gerenciamento elegante de livros, usuários e empréstimos" />
    <meta name="theme-color" content="#183d60" />

    <title>Biblioteca Áurea - Gerenciamento de Biblioteca</title>

    <link rel="icon" type="image/png" href="~/images/logo-biblioteca.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
    @{
        var controllerAtual = ViewContext.RouteData.Values["controller"]?.ToString();
        var usuarioLogado = User.Identity?.IsAuthenticated == true;
    }

    <header>
        <nav class="navbar navbar-expand-lg site-navbar fixed-top">
            <div class="container site-navbar-container">
                <a class="navbar-brand site-brand"
                   href="@Url.Action("Index", "Home")"
                   aria-label="Biblioteca Áurea - Página Inicial">
                    <img src="~/images/logo-biblioteca-completa.png"
                         alt="Logo Biblioteca Áurea"
                         class="site-logo" />
                </a>

                <button class="navbar-toggler site-navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainMenu"
                        aria-controls="mainMenu"
                        aria-expanded="false"
                        aria-label="Abrir menu de navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainMenu">
                    <ul class="navbar-nav ms-auto site-nav-list">
                        <li class="nav-item">
                            <a class="nav-link site-nav-link @(controllerAtual == "Home" ? "active" : "")"
                               href="@Url.Action("Index", "Home")"
                               aria-current="@(controllerAtual == "Home" ? "page" : "false")">
                                Home
                            </a>
                        </li>

                        @if (usuarioLogado)
                        {
                            <li class="nav-item">
                                <a class="nav-link site-nav-link @(controllerAtual == "Livros" ? "active" : "")"
                                   href="@Url.Action("Index", "Livros")"
                                   aria-current="@(controllerAtual == "Livros" ? "page" : "false")">
                                    Livros
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link site-nav-link @(controllerAtual == "Usuarios" ? "active" : "")"
                                   href="@Url.Action("Index", "Usuarios")"
                                   aria-current="@(controllerAtual == "Usuarios" ? "page" : "false")">
                                    Usuários
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link site-nav-link @(controllerAtual == "Emprestimos" ? "active" : "")"
                                   href="@Url.Action("Index", "Emprestimos")"
                                   aria-current="@(controllerAtual == "Emprestimos" ? "page" : "false")">
                                    Empréstimos
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Admin"
                                      asp-action="Logout"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link site-nav-link border-0 bg-transparent">
                                        Sair
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link site-nav-link @(controllerAtual == "Catalogo" ? "active" : "")"
                                   href="@Url.Action("Index", "Catalogo")"
                                   aria-current="@(controllerAtual == "Catalogo" ? "page" : "false")">
                                    Catálogo
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link site-nav-link @(controllerAtual == "Admin" ? "active" : "")"
                                   href="@Url.Action("Login", "Admin")"
                                   aria-current="@(controllerAtual == "Admin" ? "page" : "false")">
                                    Login Administrativo
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="site-footer-top">
                <div class="row justify-content-center text-center g-4">
                    <div class="col-lg-3 col-md-6 d-flex flex-column align-items-center text-center">
                        <h4 class="site-footer-title">Navegação</h4>
                        <ul class="site-footer-links">
                            <li><a href="@Url.Action("Index", "Home")">Home</a></li>

                            @if (usuarioLogado)
                            {
                                <li><a href="@Url.Action("Index", "Livros")">Livros</a></li>
                                <li><a href="@Url.Action("Index", "Usuarios")">Usuários</a></li>
                                <li><a href="@Url.Action("Index", "Emprestimos")">Empréstimos</a></li>
                            }
                            else
                            {
                                <li><a href="@Url.Action("Index", "Catalogo")">Catálogo</a></li>
                                <li><a href="@Url.Action("Login", "Admin")">Login Administrativo</a></li>
                            }
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6 d-flex flex-column align-items-center text-center">
                        <h4 class="site-footer-title">Sistema</h4>
                        <ul class="site-footer-links">
                            <li><a href="@Url.Action("Index", "Catalogo")">Catálogo Público</a></li>

                            @if (usuarioLogado)
                            {
                                <li><a href="@Url.Action("Index", "Livros")">Área Administrativa</a></li>
                            }
                            else
                            {
                                <li><a href="@Url.Action("Login", "Admin")">Acesso Administrativo</a></li>
                            }
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6 d-flex flex-column align-items-center text-center">
                        <h4 class="site-footer-title">Redes Sociais</h4>
                        <ul class="site-footer-links">
                            <li><a href="https://instagram.com" target="_blank" rel="noopener noreferrer">Instagram</a></li>
                            <li><a href="https://facebook.com" target="_blank" rel="noopener noreferrer">Facebook</a></li>
                            <li><a href="https://twitter.com" target="_blank" rel="noopener noreferrer">Twitter</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="site-footer-bottom text-center">
                <p>&copy; 2026 Biblioteca Áurea. Todos os direitos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>