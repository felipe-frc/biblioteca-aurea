@model Biblioteca.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login Administrativo";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<section class="crud-page crud-form-page">
    <div class="container">
        <div class="crud-header crud-header-form">
            <div>
                <h1 class="crud-title">Login Administrativo</h1>
                <span class="crud-line"></span>
                <p class="mt-3 text-muted">
                    Acesse a área administrativa para gerenciar livros, usuários e empréstimos.
                </p>
            </div>
        </div>

        <div class="crud-form-card">
            @if (TempData["Sucesso"] is not null)
            {
                <div class="crud-alert crud-alert-success">@TempData["Sucesso"]</div>
            }

            <form asp-controller="Admin" asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()

                @if (!string.IsNullOrWhiteSpace(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }

                <div asp-validation-summary="ModelOnly" class="crud-alert crud-alert-danger crud-validation-summary"></div>

                <div class="crud-form-grid">
                    <div class="crud-form-group">
                        <label asp-for="Usuario" class="crud-form-label">Usuário</label>
                        <input asp-for="Usuario" class="crud-form-control" placeholder="Digite o usuário administrativo" autocomplete="username" />
                        <span asp-validation-for="Usuario" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group">
                        <label asp-for="Senha" class="crud-form-label">Senha</label>
                        <input asp-for="Senha" class="crud-form-control" placeholder="Digite a senha" autocomplete="current-password" />
                        <span asp-validation-for="Senha" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group">
                        <label class="d-flex align-items-center gap-2">
                            <input asp-for="LembrarMe" />
                            <span>Manter conectado</span>
                        </label>
                    </div>
                </div>

                <div class="crud-form-actions">
                    <button type="submit" class="crud-primary-btn">Entrar</button>
                    <a asp-controller="Home" asp-action="Index" class="crud-secondary-btn">Voltar para Home</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
