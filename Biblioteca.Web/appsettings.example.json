{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=BibliotecaAureaDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AdminUser": {
    "Email": "admin@example.com",
    "Password": "change-this-password"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/biblioteca-aurea-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "Biblioteca Aurea"
    }
  },
  "AllowedHosts": "*"
}